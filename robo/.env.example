# Copie este arquivo para ".env" (que é ignorado pelo git) e preencha com suas chaves.
# No GitHub Actions, estes valores virão dos GitHub Secrets — nunca do código.

# Chave de API v3 do TMDb (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Chave da OMDb API (https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=

# Opcional: quantas páginas de "descobertas" novas buscar por execução (20 filmes/página).
# Padrão = 3. A fila de espera é persistente, então a cobertura cresce ao longo dos dias.
# PAGINAS_DESCOBERTA=3
